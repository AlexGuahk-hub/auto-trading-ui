{
  "installCommand": "npm ci",
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "framework": "create-react-app",
  "rewrites": [
    { "source": "/trading/:path*", "destination": "http://coreclick.duckdns.org:8080/trading/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
